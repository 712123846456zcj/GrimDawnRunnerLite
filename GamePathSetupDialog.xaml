<Window x:Class="Wpf_gdRunnerLite.GamePathSetupDialog"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="初始化游戏目录" Width="650" Height="390" ResizeMode="NoResize"
 WindowStartupLocation="CenterScreen" WindowStyle="None" AllowsTransparency="True"
 Background="Transparent" FontFamily="{StaticResource UiFont}" ShowInTaskbar="True">
 <Window.Resources>
  <Style x:Key="DialogButtonStyle" TargetType="Button">
   <Setter Property="Height" Value="42"/><Setter Property="Padding" Value="18,0"/>
   <Setter Property="Foreground" Value="#D9DEE5"/><Setter Property="Background" Value="#181C22"/>
   <Setter Property="BorderBrush" Value="#35FFFFFF"/><Setter Property="BorderThickness" Value="1"/>
   <Setter Property="Cursor" Value="Hand"/>
   <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="B" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="B" Property="Background" Value="#262B33"/><Setter TargetName="B" Property="BorderBrush" Value="#66FFFFFF"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
  </Style>
  <Style x:Key="DialogPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DialogButtonStyle}">
   <Setter Property="Foreground" Value="#17120A"/><Setter Property="Background" Value="#D7A84B"/><Setter Property="BorderBrush" Value="#F1C76E"/>
   <Setter Property="FontWeight" Value="SemiBold"/>
   <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="B" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="B" Property="Background" Value="#E4B85B"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
  </Style>
 </Window.Resources>
 <Border Background="#F20D1015" BorderBrush="#50D7A84B" BorderThickness="1" CornerRadius="14">
  <Grid>
   <Grid.RowDefinitions><RowDefinition Height="42"/><RowDefinition Height="*"/></Grid.RowDefinitions>
   <Grid Grid.Row="0" Background="#B5090B0F" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
    <StackPanel Orientation="Horizontal" Margin="15,0,0,0" VerticalAlignment="Center"><Image Width="20" Height="20" Source="Assets/GD2.png"/><TextBlock Margin="9,0,0,0" Foreground="#E8EBEF" FontSize="12" FontWeight="SemiBold" Text="GRIM DAWN RUNNER LITE"/></StackPanel>
    <Button Width="42" Height="42" HorizontalAlignment="Right" Foreground="#BDC4CC" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="CloseButton_Click"><TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10" Text="&#xE8BB;"/></Button>
   </Grid>
   <Grid Grid.Row="1" Margin="30,25,30,28">
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <StackPanel Orientation="Horizontal"><Border Width="52" Height="52" CornerRadius="12" Background="#24D7A84B" BorderBrush="#55D7A84B" BorderThickness="1"><TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="#E3B95E" Text="&#xE7BA;"/></Border><StackPanel Margin="16,2,0,0"><TextBlock Foreground="#F6F1E9" FontSize="22" FontWeight="SemiBold" Text="需要初始化游戏目录"/><TextBlock Margin="0,5,0,0" Foreground="#8F98A3" FontSize="11.5" Text="当前启动器位置没有检测到 Grim Dawn 主程序"/></StackPanel></StackPanel>
    <Border Grid.Row="1" Margin="0,22,0,0" Padding="17" Background="#15191F" BorderBrush="#2AFFFFFF" BorderThickness="1" CornerRadius="10"><StackPanel><TextBlock Foreground="#D7DCE2" FontSize="12" TextWrapping="Wrap" LineHeight="20" Text="推荐将本程序复制到《恐怖黎明》游戏根目录，再重新运行。游戏根目录通常同时包含 Grim Dawn.exe 和 x64 文件夹。"/><TextBlock Margin="0,10,0,0" Foreground="#8D96A1" FontSize="11" TextWrapping="Wrap" LineHeight="18" Text="也可以直接选择根目录或 x64 / x86 文件夹中的 Grim Dawn.exe，启动器会自动识别并保存游戏根目录。"/></StackPanel></Border>
    <StackPanel Grid.Row="2" Margin="2,16,2,0"><TextBlock x:Name="SetupStatusText" Foreground="#B78E49" FontSize="11" TextWrapping="Wrap" Text="请选择下面的处理方式。"/><TextBlock Margin="0,7,0,0" Foreground="#5F6873" FontSize="10" Text="自定义路径将保存到程序目录下的 settings.json"/></StackPanel>
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"><Button Width="100" Style="{StaticResource DialogButtonStyle}" IsCancel="True" Click="ConfirmButton_Click" Content="退出"/><Button Width="190" Margin="12,0,0,0" Style="{StaticResource DialogPrimaryButtonStyle}" IsDefault="True" Click="SelectExecutableButton_Click" Content="自定义主程序路径"/></StackPanel>
   </Grid>
  </Grid>
 </Border>
</Window>
