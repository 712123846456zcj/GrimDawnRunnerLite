<Window x:Class="Wpf_gdRunnerLite.MainWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Grim Dawn Runner Lite" Width="1180" Height="760" MinWidth="980" MinHeight="650"
 WindowStartupLocation="CenterScreen" WindowStyle="None" ResizeMode="CanResize"
 Background="#090B0F" Icon="Assets/GD2.png" FontFamily="{StaticResource UiFont}"
 UseLayoutRounding="True" SnapsToDevicePixels="True" StateChanged="Window_StateChanged">
    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="38"
            ResizeBorderThickness="5"
            GlassFrameThickness="0"
            CornerRadius="0"
            UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <LinearGradientBrush x:Key="WindowBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#11141A" Offset="0"/>
            <GradientStop Color="#0B0D11" Offset="0.55"/>
            <GradientStop Color="#15100B" Offset="1"/>
        </LinearGradientBrush>
        <Style x:Key="WindowButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Foreground" Value="#C8CDD5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#22FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource WindowButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#D83B3B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="12,3"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Foreground" Value="#ADB4BE"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#16FFFFFF"/>
                                <Setter Property="Foreground" Value="#ECEFF3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LaunchButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#FFF7F1"/>
            <Setter Property="Background" Value="#C91A1E24"/>
            <Setter Property="BorderBrush" Value="#2AFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Card" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Card" Property="Background" Value="#E9252930"/>
                                <Setter TargetName="Card" Property="BorderBrush" Value="#80D7A84B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Card" Property="Opacity" Value="0.42"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="UtilityButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Foreground" Value="#D8DDE4"/>
            <Setter Property="Background" Value="#18FFFFFF"/>
            <Setter Property="BorderBrush" Value="#25FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#27FFFFFF"/>
                                <Setter TargetName="B" Property="BorderBrush" Value="#55FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource UtilityButtonStyle}">
            <Setter Property="Foreground" Value="#17130D"/>
            <Setter Property="Background" Value="#D7A84B"/>
            <Setter Property="BorderBrush" Value="#F0C871"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="B" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#E9BC62"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="B" Property="Background" Value="#BD8F37"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="13,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#F1F3F5"/>
            <Setter Property="CaretBrush" Value="#D7A84B"/>
            <Setter Property="Background" Value="#B812151A"/>
            <Setter Property="BorderBrush" Value="#35FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="B" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="B" Property="BorderBrush" Value="#B8D7A84B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PanelStyle" TargetType="Border">
            <Setter Property="Background" Value="#B516191E"/>
            <Setter Property="BorderBrush" Value="#25FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
    </Window.Resources>

    <Border x:Name="WindowBorder" BorderThickness="0" Background="{StaticResource WindowBackground}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="#B0090B0F" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="552*"/>
                    <ColumnDefinition Width="421*"/>
                    <ColumnDefinition Width="44*"/>
                    <ColumnDefinition Width="25*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0" IsHitTestVisible="False" Grid.ColumnSpan="4">
                    <Image Width="20" Height="20" Source="Assets/GD1.png"/>
                    <TextBlock Margin="9,0,0,0" VerticalAlignment="Center" Foreground="#E7E9ED" FontSize="12.5" FontWeight="SemiBold" Text="GRIM DAWN RUNNER LITE"/>
                    <Border Margin="10,0,0,0" Padding="7,2" CornerRadius="4" Background="#23D7A84B">
                        <TextBlock Foreground="#DDBB70" FontSize="10" FontWeight="SemiBold" Text="1.0"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="4" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource WindowButtonStyle}" Click="MinimizeButton_Click">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10" Text="&#xE921;"/>
                    </Button>
                    <Button Style="{StaticResource WindowButtonStyle}" Click="MaximizeButton_Click">
                        <TextBlock x:Name="MaximizeGlyph" FontFamily="Segoe MDL2 Assets" FontSize="10" Text="&#xE922;"/>
                    </Button>
                    <Button Style="{StaticResource CloseButtonStyle}" Click="CloseButton_Click">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="10" Text="&#xE8BB;"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#D50D1014" BorderBrush="#20FFFFFF" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Margin="18,24,18,20">
                            <Border Width="70" Height="70" HorizontalAlignment="Left" CornerRadius="15" ClipToBounds="True" BorderBrush="#55D7A84B" BorderThickness="1">
                                <Image Source="Assets/GD1.png" Stretch="UniformToFill" Margin="0,-1,0,-16" RenderTransformOrigin="0.746,0.522" HorizontalAlignment="Center" Cursor="Hand" Width="174"/>
                            </Border>
                            <TextBlock Margin="0,13,0,0" Foreground="White" FontFamily="Georgia" FontSize="20" FontWeight="Bold" Text="Grim Dawn 1.3"/>
                            <TextBlock Margin="0,4,0,0" Foreground="#77818D" FontSize="11" Text="简易启动工具(免费开源)"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1">
                            <Button x:Name="NavHomeButton" Tag="home" Style="{StaticResource NavButtonStyle}" Click="NavigationButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Width="28" FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE80F;"/>
                                    <TextBlock Text="主页"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavAccountButton" AutomationProperties.Name="OpenAccountPage" Tag="account" Style="{StaticResource NavButtonStyle}" Click="NavigationButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Width="28" FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE77B;"/>
                                    <TextBlock Text="离线和联机"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavModsButton" Tag="mods" Style="{StaticResource NavButtonStyle}" Click="NavigationButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Width="28" FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE74C;"/>
                                    <TextBlock Text="Mod 管理"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavLocalizationButton" Tag="localization" Style="{StaticResource NavButtonStyle}" Click="NavigationButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Width="28" FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE8C1;"/>
                                    <TextBlock Text="汉化管理"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavUsageButton" Tag="usage" Style="{StaticResource NavButtonStyle}" Click="NavigationButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Width="28" FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE897;"/>
                                    <TextBlock Text="使用说明"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="NavAboutButton" Tag="about" Style="{StaticResource NavButtonStyle}" Click="NavigationButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Width="28" FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE946;"/>
                                    <TextBlock Text="关于"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <Border Grid.Row="2" Margin="14,0,14,17" Padding="13" Background="#14FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1" CornerRadius="9">
                            <StackPanel>
                                <DockPanel>
                                    <Ellipse x:Name="RootStatusDot" Width="7" Height="7" Margin="0,0,8,0" VerticalAlignment="Center" Fill="#6F7882"/>
                                    <TextBlock x:Name="RootStatusText" Foreground="#C8CDD4" FontSize="11" Text="正在检查…"/>
                                </DockPanel>
                                <TextBlock x:Name="CurrentRootText" Margin="0,7,0,0" Foreground="#67717C" FontSize="9.5" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                                <TextBlock x:Name="ArchitectureText" Margin="0,6,0,0" Foreground="#B89653" FontSize="10"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="88"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="34"/>
                    </Grid.RowDefinitions>
                    <Grid Margin="34,0,34,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="PageTitleText" Foreground="#F7F2EA" FontSize="25" FontWeight="SemiBold" Text="主页 "/>
                            <TextBlock x:Name="PageSubtitleText" Margin="0,5,0,0" Foreground="#7F8894" FontSize="11.5" Text="选择启动方式并快速访问常用目录"/>
                        </StackPanel>
                        <Button Grid.Column="1" Width="42" Height="42" Style="{StaticResource UtilityButtonStyle}" Click="RefreshButton_Click" ToolTip="刷新全部状态">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE72C;"/>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="1" Margin="34,0,34,12">
                        <!-- 主页 -->
                        <Grid x:Name="HomePage">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="290"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" CornerRadius="14" ClipToBounds="True" BorderBrush="#33FFFFFF" BorderThickness="1">
                                <Grid>
                                    <Image Source="/Assets/GD2.png" Stretch="UniformToFill" Opacity="0.72"/>
                                    <Rectangle>
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#22101010"/>
                                                <GradientStop Color="#E20B0D11" Offset="0.67"/>
                                                <GradientStop Color="#FF0B0D11" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <Grid Margin="22">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,132">
                                            <TextBlock Foreground="#DBB767" FontSize="10.5" FontWeight="Bold"><Run Language="zh-cn" Text="2026-07-23"/></TextBlock>
                                            <TextBlock Margin="0,7,0,0" Foreground="White" FontFamily="Georgia" FontSize="27" FontWeight="Bold" TextWrapping="Wrap"><Run Language="zh-cn" Text="New DLC: Grim Dawn - Fangs of Asterkarn"/></TextBlock>
                                        </StackPanel>
                                        <Border Grid.Row="1" Padding="13" Background="#C3171A1F" BorderBrush="#28FFFFFF" BorderThickness="1" CornerRadius="10">
                                            <StackPanel>
                                                <TextBlock Foreground="#818B96" FontSize="10.5" Text="运行提示"/>
                                                <TextBlock Margin="0,5,0,0" Foreground="#D3D7DC" FontSize="11" TextWrapping="Wrap" Text="DX9 不只面向旧设备，也可作为新系统长时间运行闪退时的兼容方案。"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="RecommendationText" Foreground="#9AA2AD" FontSize="11.5" TextWrapping="Wrap"/>
                                <Button x:Name="LaunchX64Button" Grid.Row="1" Margin="0,14,0,0" Style="{StaticResource LaunchButtonStyle}" Tag="x64" Click="LaunchButton_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="40" Height="40" CornerRadius="9" Background="#29D7A84B">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#E6C273" FontSize="14" FontWeight="Bold" Text="64"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Foreground="White" FontSize="14" FontWeight="SemiBold" Text="Grim Dawn · x64"/>
                                                <Border Margin="8,0,0,0" Padding="6,2" Background="#234FC778" CornerRadius="4">
                                                    <TextBlock Foreground="#7DDB9D" FontSize="9" FontWeight="Bold" Text="推荐"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Margin="0,4,0,0" Foreground="#88919C" FontSize="10.5" Text="x64\Grim Dawn.exe · 根目录工作路径"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Ellipse x:Name="X64StatusDot" Width="7" Height="7" Margin="0,0,14,0" Fill="#6F7882"/>
                                            <Border Padding="13,7" Background="#D7A84B" CornerRadius="7">
                                                <TextBlock Foreground="#17130D" FontSize="11" FontWeight="Bold" Text="▶ 启动"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button x:Name="LaunchX86Button" Grid.Row="2" Margin="0,10,0,0" Style="{StaticResource LaunchButtonStyle}" Tag="x86" Click="LaunchButton_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="40" Height="40" CornerRadius="9" Background="#224C8CD8">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#7AB4F1" FontSize="14" FontWeight="Bold" Text="32"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Foreground="White" FontSize="14" FontWeight="SemiBold" Text="Grim Dawn · x86 兼容"/>
                                            <TextBlock Margin="0,4,0,0" Foreground="#88919C" FontSize="10.5" Text="Grim Dawn.exe · 32 位兼容启动"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Ellipse x:Name="X86StatusDot" Width="7" Height="7" Margin="0,0,14,0" Fill="#6F7882"/>
                                            <Border Padding="13,7" Background="#3979B9" CornerRadius="7">
                                                <TextBlock Foreground="White" FontSize="11" FontWeight="Bold" Text="▶ 启动"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Button x:Name="LaunchLegacyButton" Grid.Row="3" Margin="0,10,0,0" Style="{StaticResource LaunchButtonStyle}" Tag="legacy" Click="LaunchButton_Click">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="40" Height="40" CornerRadius="9" Background="#22B56A58">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#E39A86" FontSize="11" FontWeight="Bold" Text="DX9"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Foreground="White" FontSize="14" FontWeight="SemiBold" Text="x86 · DirectX 9 兼容"/>
                                            <TextBlock x:Name="LegacyLaunchHint" Margin="0,4,0,0" Foreground="#88919C" FontSize="10.5" Text="检测 DX9 启动方式中"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Ellipse x:Name="LegacyStatusDot" Width="7" Height="7" Margin="0,0,14,0" Fill="#6F7882"/>
                                            <Border Padding="13,7" Background="#A65D4D" CornerRadius="7">
                                                <TextBlock Foreground="White" FontSize="11" FontWeight="Bold" Text="▶ 启动"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <Border Grid.Row="4" Margin="0,14,0,0" Padding="13,10" VerticalAlignment="Top" Background="#11FFFFFF" BorderBrush="#20FFFFFF" BorderThickness="1" CornerRadius="9" Height="50">
                                    <CheckBox x:Name="CloseAfterLaunchCheckBox" Foreground="#AEB5BE" FontSize="16" IsChecked="True" Content="成功启动后关闭本启动器" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </Border>
                                <UniformGrid Grid.Row="5" Columns="4">
                                    <Button Margin="0,0,5,0" Style="{StaticResource UtilityButtonStyle}" Click="CreateDesktopShortcutButton_Click">
                                        <TextBlock Text="创建桌面图标"/>
                                    </Button>
                                    <Button Margin="2,0" Style="{StaticResource UtilityButtonStyle}" Click="OpenSaveButton_Click">
                                        <TextBlock Text="打开存档"/>
                                    </Button>
                                    <Button Margin="2,0" Style="{StaticResource UtilityButtonStyle}" Click="OpenRootButton_Click">
                                        <TextBlock Text="游戏根目录"/>
                                    </Button>
                                    <Button Margin="5,0,0,0" Style="{StaticResource UtilityButtonStyle}" Click="CopyRootButton_Click">
                                        <TextBlock Text="复制路径"/>
                                    </Button>
                                </UniformGrid>
                            </Grid>
                        </Grid>

                        <!-- 联机账户 -->
                        <ScrollViewer x:Name="AccountPage" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                            <StackPanel MaxWidth="850" HorizontalAlignment="Left">
                                <Border Style="{StaticResource PanelStyle}" Padding="20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="36" Height="36" CornerRadius="9" Background="#29D7A84B">
                                            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#E5BF6D" FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE77B;"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Foreground="#F1F3F5" FontSize="14" FontWeight="SemiBold" Text="联机唯一标识"/>
                                            <TextBlock Margin="0,5,0,0" Foreground="#8E97A2" FontSize="11.5" TextWrapping="Wrap" Text="account_name 与 account_steamid 用于局域网或远程联机识别。参与联机的每位玩家应使用不同的名称和 17 位 ID。"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Grid Margin="0,18,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
